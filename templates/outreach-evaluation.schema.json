{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": [
    "evaluation_id",
    "draft_id",
    "lead_id",
    "company_name",
    "recipient_email",
    "language",
    "evaluated_body_hash",
    "language_fit_score",
    "personalization_score",
    "claim_risk_score",
    "spam_risk_score",
    "reply_likelihood_score",
    "overall_score",
    "decision",
    "blocking_reasons",
    "review_reasons",
    "recommended_actions",
    "created_at"
  ],
  "properties": {
    "evaluation_id": {"type": "string"},
    "draft_id": {"type": "string"},
    "lead_id": {"type": "string"},
    "company_name": {"type": "string"},
    "recipient_email": {"type": "string"},
    "language": {"type": "string"},
    "evaluated_body_hash": {"type": "string"},
    "language_fit_score": {"type": "number", "minimum": 0, "maximum": 1},
    "personalization_score": {"type": "number", "minimum": 0, "maximum": 1},
    "claim_risk_score": {"type": "number", "minimum": 0, "maximum": 1},
    "spam_risk_score": {"type": "number", "minimum": 0, "maximum": 1},
    "reply_likelihood_score": {"type": "number", "minimum": 0, "maximum": 1},
    "overall_score": {"type": "number", "minimum": 0, "maximum": 1},
    "decision": {"type": "string", "enum": ["pass", "review", "reject"]},
    "blocking_reasons": {"type": "array", "items": {"type": "string"}},
    "review_reasons": {"type": "array", "items": {"type": "string"}},
    "recommended_actions": {"type": "array", "items": {"type": "string"}},
    "created_at": {"type": "string"}
  },
  "additionalProperties": false
}
